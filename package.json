{
  "name": "mycleancity",
  "version": "1.0.0",
  "description": "Smart Civic Cleanliness Monitoring System",
  "main": "index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd backend && npm run dev",
    "client": "cd frontend && npm start",
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install",
    "build": "cd frontend && npm run build"
  },
  "keywords": ["civic", "cleanliness", "monitoring", "react", "nodejs"],
  "author": "MyCleanCity Team",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}